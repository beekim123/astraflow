# Local full Docker runtime
# Copy this file to infra/env/.env.local and fill private values there.
# infra/env/.env.local is ignored by git.

# Internal service URLs and token.
AI_GATEWAY_INTERNAL_TOKEN=local-dev-token
AI_GATEWAY_TIMEOUT_SECONDS=120
AI_GATEWAY_URL=http://ai-gateway:8010
MCP_LLM_GATEWAY_URL=http://mcp-llm-gateway:8020

# LLM provider config. Prefer ARK_* when using Volcano Ark.
ARK_BASE_URL=
ARK_API_KEY=
ARK_CHAT_MODEL=
ARK_EMBEDDING_MODEL=

# Generic OpenAI-compatible fallback names.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
