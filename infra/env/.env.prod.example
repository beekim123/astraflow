# Compose runtime
COMPOSE_PROJECT_NAME=astraflow
HTTP_PORT=18000
HTTPS_PORT=18443
NGINX_CONF=nginx.prod.conf
HEALTHCHECK_URL=http://127.0.0.1:18000/api/health

# App
APP_ENV=prod
APP_NAME=AstraFlow AI
APP_DEBUG=false
DISPLAY_TIMEZONE=Asia/Shanghai
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GATE_COOKIE_SECURE=false
UPLOAD_DIR=var/uploads
UPLOAD_IMAGE_MAX_MB=10
UPLOAD_FILE_MAX_MB=50
UPLOAD_VIDEO_MAX_MB=200
AI_GATEWAY_INTERNAL_TOKEN=replace-with-internal-service-token
AI_GATEWAY_TIMEOUT_SECONDS=120
AI_GATEWAY_URL=http://ai-gateway:8010
LLM_PROVIDER_URL=http://llm-provider:8020
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
ARK_BASE_URL=
ARK_API_KEY=
ARK_CHAT_MODEL=
ARK_EMBEDDING_MODEL=

# Domain and CORS
PUBLIC_ORIGIN=http://localhost:18000
CORS_ORIGINS=http://localhost:18000

# PostgreSQL
POSTGRES_DB=astraflow
POSTGRES_USER=astraflow
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql+asyncpg://astraflow:replace-with-strong-db-password@postgres:5432/astraflow

# Redis
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

# Frontend build args
VITE_API_BASE_URL=/api
VITE_PORTAL_URL=/
VITE_APP_ADMIN_URL=/micro/admin/
VITE_APP_CHAT_URL=/micro/chat/
VITE_APP_AUDIT_URL=/micro/audit/
VITE_APP_TICKET_URL=/micro/ticket/
VITE_APP_CUSTOMER_H5_URL=/micro/customer/
VITE_APP_MARKETING_URL=/micro/marketing/
