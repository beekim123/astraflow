{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AstraFlow Backend Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--port", "18080"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    }
  ]
}
